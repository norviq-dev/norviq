# SPDX-License-Identifier: Apache-2.0
# Multi-stage build for minimal image

FROM python:3.12-slim AS builder
WORKDIR /build
COPY pyproject.toml .
COPY norviq/ norviq/
# [spiffe] extra installs pyspiffe so NRVQ_SPIFFE_MODE=workload-api works (import-guarded; mock unaffected).
RUN pip install --no-cache-dir --target=/deps '.[spiffe]'

FROM python:3.12-slim
WORKDIR /app
COPY --from=builder /deps /usr/local/lib/python3.12/site-packages
COPY norviq/ norviq/
COPY policies/ policies/

# OPA arch matches the build target (TARGETARCH = amd64|arm64; AKS=amd64, local kind on Apple Silicon=arm64).
ARG TARGETARCH=amd64
# DEF-002: build-provenance stamp (broadcast by CI: build.yml build-args NRVQ_GIT_SHA=github.sha).
ARG NRVQ_GIT_SHA=unknown
# Install the OPA binary so the `subprocess` rollback mode works in-cluster (server mode uses the
# OPA sidecar and does not need this; kept for parity with Dockerfile.api). Pinned to the same version
# as the Helm sidecar image (openpolicyagent/opa:1.18.0-static) and integrity-checked against the
# published SHA256 digest so a compromised/mismatched download fails the build closed instead of
# silently installing an unverified decision-engine binary.
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates && \
    case "${TARGETARCH}" in \
        amd64) OPA_SHA256="65d700b14b99b354982b61031b40bdc8e316ea93dadd61818f066d1d9a69dcce" ;; \
        arm64) OPA_SHA256="93499a6eead5277ba1a52304111103ec4e7779d4f6b11716a4f07905b7ee4a96" ;; \
        *) echo "unsupported TARGETARCH: ${TARGETARCH}" >&2; exit 1 ;; \
    esac && \
    curl -fL -o /usr/local/bin/opa "https://openpolicyagent.org/downloads/v1.18.0/opa_linux_${TARGETARCH}_static" && \
    echo "${OPA_SHA256}  /usr/local/bin/opa" | sha256sum -c - && \
    chmod +x /usr/local/bin/opa && \
    opa version && \
    apt-get remove -y curl && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

# DEF-002: uniform build provenance across ALL shipped images (mirrors Dockerfile.api:18-19,41), not just
# api. Stamped AFTER the OPA layer so changing the SHA busts only these trivial layers, never the OPA
# download cache. NRVQ_BUILD_GIT_SHA is the runtime NO-STALE marker; the label is the OCI revision.
ENV NRVQ_BUILD_GIT_SHA=${NRVQ_GIT_SHA}
LABEL org.opencontainers.image.revision=${NRVQ_GIT_SHA}
RUN printf "%s\n" "${NRVQ_GIT_SHA}" > /app/.build_git_sha

# DEF-029: pin a NUMERIC uid and reference it numerically in USER so kubelet can verify the
# securityContext runAsNonRoot=true (a name-based `USER norviq` fails with "non-numeric user").
RUN useradd -r -u 999 -s /usr/sbin/nologin norviq
USER 999

EXPOSE 8282
ENV NRVQ_SOCKET_PATH=/tmp/norviq-proxy.sock
ENV NRVQ_HTTP_FALLBACK_PORT=8282

CMD ["python", "-m", "norviq.sidecar"]

# SPDX-License-Identifier: Apache-2.0
# Multi-stage build for minimal UI image

FROM node:20-alpine AS builder
WORKDIR /build
COPY ui/package*.json ./
RUN npm ci
COPY ui/ .
RUN npm run build

FROM nginx:alpine
# Patch fixable OS-package CVEs in the base at build time (e.g. curl/libcurl HIGHs) so the shipped
# image isn't stale relative to the alpine security repo — keeps the fail-closed Trivy image gate green
# without ignoring genuinely-fixable vulns.
# NRVQ_GIT_SHA changes every commit, so this layer is NEVER served stale from the CI docker layer
# cache (cache-to gha,mode=max): `apk upgrade` re-runs each build and pulls the latest patched
# packages, instead of a cached pre-CVE layer (the cause of curl 8.19.0-r0 shipping after 8.20.0-r0
# was published). This is the durable fix — future OS CVEs are picked up automatically.
ARG NRVQ_GIT_SHA=dev
RUN apk update && apk upgrade --no-cache && echo "os-patched @ ${NRVQ_GIT_SHA}"
COPY --from=builder /build/dist /usr/share/nginx/html
COPY ui/nginx.conf /etc/nginx/conf.d/default.conf
COPY ui/docker-entrypoint.sh /docker-entrypoint.d/99-nrvq-config.sh
RUN chmod +x /docker-entrypoint.d/99-nrvq-config.sh
# Single-cluster default: an empty fleet-proxy include so nginx starts with no fleet-api dependency; the entrypoint
# overwrites it with the real proxy block only when FLEET_API_URL is set (the hub).
RUN touch /etc/nginx/fleet-proxy.conf

EXPOSE 80
# F-25: the entrypoint writes /config.js from FLEET_API_URL, then runs nginx.
CMD ["/docker-entrypoint.d/99-nrvq-config.sh"]

# SPDX-License-Identifier: Apache-2.0
# Local dev only - copy to .env.local and set the token

# Generate with:
# python -c "from jose import jwt; print(jwt.encode({'sub':'admin','role':'admin'}, 'change-me-in-production', algorithm='HS256'))"
VITE_DEV_TOKEN=

# Optional: override the API base URL. Leave empty to use the vite dev proxy (127.0.0.1:8080).
VITE_API_BASE_URL=

# Environment label (default cluster shown in the UI selector).
VITE_ENV_LABEL=local

# OIDC SSO (A3). Set BOTH to log in via a real IdP (Auth Code + PKCE) instead of VITE_DEV_TOKEN.
# identity-local Keycloak: issuer http://keycloak.localtest.me:8080/realms/norviq, client norviq-console.
# Platform-agnostic: point at Entra/Okta/Auth0 by swapping the issuer + client id (no code change).
VITE_OIDC_ISSUER=
VITE_OIDC_CLIENT_ID=
# VITE_OIDC_REDIRECT_URI=   # defaults to <origin>/auth/callback

# Multi-cluster fleet (F045). Set to a fleet-api hub URL to show the cross-cluster Fleet view.
VITE_FLEET_API_URL=

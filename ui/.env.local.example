# Local dev only - copy to .env.local and set the token

# Generate with:
# python -c "from jose import jwt; print(jwt.encode({'sub':'admin','role':'admin'}, 'change-me-in-production', algorithm='HS256'))"
VITE_DEV_TOKEN=

# Optional: override the API base URL. Leave empty to use the vite dev proxy (127.0.0.1:8080).
VITE_API_BASE_URL=

# Environment label (default cluster shown in the UI selector).
VITE_ENV_LABEL=local

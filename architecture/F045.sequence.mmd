%% F045 fleet P1: spoke relay push + console aggregated read. The enforce path NEVER touches the hub.
sequenceDiagram
    participant Spoke as Spoke API (relay)
    participant Hub as fleet-api
    participant FDB as fleet-postgresql
    participant Console

    loop every fleet_relay_interval_s (fire-and-forget)
        Spoke->>Spoke: read agent_registry + aggregate audit_log (trailing window)
        Spoke->>Hub: POST /clusters/{id}/heartbeat (Bearer: OIDC-CC | HS256)
        Hub->>FDB: upsert cluster, last_heartbeat=now
        Spoke->>Hub: POST /clusters/{id}/rollup {agents, audit}
        Hub->>Hub: require_admin_or_service + scoped_cluster(path id)
        Hub->>FDB: upsert agent_rollup + audit_rollup (SET-absolute -> idempotent)
        Note over Spoke,Hub: hub down -> POST fails, logged NRVQ-FLT-15001, local enforcement UNAFFECTED
    end

    Console->>Hub: GET /fleet/clusters | /fleet/agents | /fleet/audit/summary (Bearer)
    Hub->>Hub: scoped_cluster(user, ?cluster=) -> filter to allowed cluster(s)
    Hub->>FDB: select (cluster-scoped)
    FDB-->>Hub: rows
    Hub-->>Console: aggregated, RBAC-scoped view (per-cluster status: healthy/stale)

%% --- P2 signed policy-push (hub serves SIGNED bundles; the spoke's pubkey is the trust root) ---
Console->>Hub: POST /fleet/policies (require_admin) -> NRVQ-FLT-15021 authored
loop every fleet_pull_interval_s (FleetPolicyPuller; gated; fails closed if pubkey unset)
    Spoke->>Hub: GET /clusters/{id}/bundle (Bearer + SPIFFE id)
    Hub->>Hub: resolve selector+override -> bump-on-change version -> sign_bundle(canonical_bytes, fleet_signing_key)
    Hub-->>Spoke: {payload, jws}  NRVQ-FLT-15015
    Spoke->>Spoke: verify_bundle(body, fleet_bundle_pubkey): recompute==signed bytes [reject->15018, keep last-good]
    Spoke->>Spoke: cluster_id + temporal nbf/exp [15019] + version>last_applied [15017]
    Spoke->>Spoke: PolicyLoader.create(...) per policy -> persist FleetBundleState AFTER full loop  NRVQ-FLT-15022
    Spoke->>Hub: POST /clusters/{id}/rollout {bundle_version,state,applied_version}  NRVQ-FLT-15020
    Hub->>FDB: PolicyRollout state machine (pending/applied/failed/diverged)
    Note over Spoke,Hub: hub down OR tampered/unsigned/replayed -> NO apply, last-good enforced, attacks 75/75
end
Console->>Hub: GET /clusters/{id}/audit/records (P3 drill-down; residency -> NRVQ-FLT-15026 blocked)

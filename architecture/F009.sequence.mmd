sequenceDiagram
    participant Caller
    participant Eval as OPAEvaluator
    participant Cache as RedisCache
    participant Opa as OpaClient
    participant Server as OPA server

    Caller->>Eval: evaluate(event)
    Eval->>Eval: _validate_spiffe(spiffe_id)
    Eval->>Cache: get_trust(spiffe_id) + compute trust
    Eval->>Cache: get_eval(namespace, class, cache_tool)
    alt cache hit
        Cache-->>Eval: PolicyDecision
        Eval->>Eval: _apply_trust_overrides(...)
        Eval-->>Caller: cached decision
    else cache miss
        Eval->>Eval: _collect_candidates(event)
        loop each candidate (no semaphore in server mode)
            alt opa_mode == server
                Eval->>Opa: push_policy(module_id, rewritten rego) [if changed]
                Eval->>Server: POST /v1/data/norviq/managed/<key> {input}
                Server-->>Eval: {decision, rule_id, reason}
                Note over Eval,Server: timeout / error / undefined -> fail CLOSED (block)
            else opa_mode == subprocess
                Eval->>Eval: opa eval fork (tempfile) [rollback path]
            end
        end
        Eval->>Eval: _resolve_precedence(results)
        Eval->>Cache: set_eval(...) [if rule cacheable]
        Eval->>Eval: _apply_trust_overrides(...)
        Eval-->>Caller: PolicyDecision
    end

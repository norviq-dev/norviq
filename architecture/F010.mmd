sequenceDiagram
    participant Caller as API/Webhook/Sidecar
    participant Loader as PolicyLoader
    participant Mem as In-Memory Map
    participant Redis as RedisCache
    participant Eval as OPAEvaluator

    Caller->>Loader: load(ns, cls)
    Loader->>Mem: lookup ns:cls
    alt memory hit
        Mem-->>Loader: rego
        Loader-->>Caller: rego
    else memory miss
        Loader->>Redis: get_policy(ns, cls)
        alt redis hit
            Redis-->>Loader: rego
            Loader->>Mem: copy-on-write update
            Loader-->>Caller: rego
        else not found
            Loader-->>Caller: None
        end
    end

    Caller->>Loader: create(ns, cls, rego, saved_by)
    Loader->>Loader: append version (cap 10, copy-on-write)
    Loader->>Mem: copy-on-write update
    Loader->>Redis: set_policy(ns, cls, rego)
    Loader->>Eval: load_policy(ns, cls, rego)
    Loader-->>Caller: version int


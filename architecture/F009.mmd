    classDef blue fill:#dbeafe,stroke:#1d4ed8,color:#1e3a8a;

sequenceDiagram
    participant Caller as F011/F012/F015
    participant Eval as OPAEvaluator
    participant Cache as RedisCache
    participant OPA as Inline Rules
    participant Audit as Async Audit

    Caller->>Eval: evaluate(event)
    Eval->>Cache: get_eval(ns, class, tool)
    alt Cache hit
        Cache-->>Eval: PolicyDecision
        Eval-->>Caller: cached PolicyDecision
    else Cache miss
        Eval->>Cache: get_trust(spiffe_id)
        Eval->>Eval: _build_input(event, trust)
        Eval->>Eval: acquire Semaphore(10)
        Eval->>OPA: _evaluate_opa(ns, class, input)
        OPA-->>Eval: result
        Eval->>Eval: _build_decision(result,...)
        Eval->>Cache: set_eval(ns, class, tool, decision)
        alt decision=block
            Eval->>Cache: decrement_trust(spiffe_id)
        end
        Eval--)Audit: create_task(_emit_audit(decision))
        Eval-->>Caller: PolicyDecision
    end


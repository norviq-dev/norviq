sequenceDiagram
    participant Caller
    participant Loader as PolicyLoader
    participant Cache as RedisCache
    participant Eval as OPAEvaluator

    Caller->>Loader: create(namespace, class, rego_source, saved_by)
    Loader->>Loader: update _versions and _policies
    Loader->>Cache: set_policy(namespace, class, rego_source)
    Loader->>Eval: load_policy(namespace, class, rego_source)
    Loader-->>Caller: version int

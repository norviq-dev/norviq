classDiagram
    class AuditEmitter {
        -set~Task~ _tasks
        -Tracer _tracer
        +init() None
        +emit(event, decision, payload) None
        +close() None
        -_do_emit(event, decision, payload) None
        -_write_db(record) None
        -_emit_span(event, decision) None
    }
    class ToolCallEvent
    class PolicyDecision
    class AuditRecord
    class AuditLogEntry
    class Settings

    AuditEmitter --> ToolCallEvent : consumes
    AuditEmitter --> PolicyDecision : consumes

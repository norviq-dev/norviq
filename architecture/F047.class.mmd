%% F047 sector starter policy packs — catalog + enable/disable + additive evaluator candidate.
classDiagram
    class PackLib {
        +load_manifest() dict
        +catalog() list~dict~
        +is_known(pack_id) bool
        +pack_priority() int
        +combine(pack_ids) str  %% union PACK-CONTRIB + one RESOLVER under package norviq.pack
        -_read_rego(pack_id) str
        -_between(text, begin, end) str
    }
    class PacksRouter {
        +list_packs(namespace, user, session) list~dict~  %% GET /policy-packs  NRVQ-API-7094
        +enable_pack(pack_id, body, request, user, session) dict  %% admin  NRVQ-API-7095
        +disable_pack(pack_id, body, request, user, session) dict  %% admin  NRVQ-API-7096
        -_enabled_ids(session, namespace) list~str~
        -_materialize(request, namespace, session) list~str~
    }
    class NamespacePack {
        +namespace: str  %% PK
        +pack_id: str  %% PK
        +enabled_by: str
        +enabled_at: datetime
    }
    class NamespaceSettings {
        +namespace: str  %% PK
        +enforcement_mode: str
        +sector: str  %% F047 org hint
    }
    class PolicyLoader {
        +create(ns, agent_class, rego, priority, enforcement_mode, policy_name) int
        +delete(ns, agent_class) bool
        -_policies: dict
    }
    class OPAEvaluator {
        -_collect_candidates(event) list~dict~  %% adds (ns,__pack__) in-memory only
        +_resolve_with_packs(results) dict  %% additive-only overlay (tighten-only)
        -_resolve_precedence(results) dict
    }
    PacksRouter --> PackLib : catalog + combine
    PacksRouter --> NamespacePack : enabled state
    PacksRouter --> PolicyLoader : materialize (ns,__pack__)
    PackLib ..> SectorPacks : reads policies/sector/*.rego + packs.json
    OPAEvaluator --> PolicyLoader : reads _policies[(ns:__pack__)]
    class SectorPacks {
        +energy.rego  %% ot_control_command_blocked / ot_adjacent_write_escalate / ot_surface_review_escalate
        +finance.rego  %% wire_over_threshold_escalate / new_beneficiary_escalate / sod_violation (requires pci)
        +healthcare.rego  %% clinical_action_escalate / phi_min_necessary / phi_identifier_egress (requires pii)
        +government.rego  %% rights_impacting_escalate / cui_fti_egress_blocked (requires pii)
        +telecom.rego  %% sim_swap_escalate / cpni_bulk_blocked
        +erp-crm.rego  %% erp_financial_posting_escalate / erp_bank_detail_change_blocked / erp_sod_violation (requires pii)
        +media-entertainment.rego  %% media_prerelease_blocked / media_drm_key_access_blocked / media_distribute_escalate (requires pii)
        +ecommerce.rego  %% ecom_refund_over_threshold_escalate / ecom_price_manipulation_blocked (requires pci,pii)
    }
    class SharedHorizontal {
        +horizontal.rego  %% canonical pci_card_numbers / pii_detection composed via packs.json requires
    }
    PackLib ..> SharedHorizontal : composes by `requires`

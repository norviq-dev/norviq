sequenceDiagram
    participant U as API Client
    participant A as FastAPI App
    participant L as PolicyLoader
    participant R as RedisCache
    participant D as PostgreSQL

    A->>D: init_db() + create_tables()
    A->>R: connect()
    A->>A: init evaluator/emitter/loader
    U->>A: POST /api/v1/policies
    A->>L: create(namespace, class, rego)
    L->>R: set_policy(...)
    U->>A: GET /api/v1/audit/records
    A->>D: SELECT audit_log
    U->>A: PUT /api/v1/agents/{id}/trust
    A->>R: set_trust(...)
    A->>R: close()
    A->>D: close_db()

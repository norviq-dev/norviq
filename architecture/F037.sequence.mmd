sequenceDiagram
    participant API as Graph Router
    participant Analyzer as GraphAnalyzer
    participant Attack as AttackGraphEngine
    participant NX as networkx
    API->>Analyzer: full_analysis()
    Analyzer->>Attack: get_summary()
    Analyzer->>Attack: find_chokepoints()
    Analyzer->>Attack: find_critical_paths()
    loop each agent
        Analyzer->>Attack: compute_blast_radius(agent)
        Attack->>NX: descendants(agent)
        Attack->>NX: all_simple_paths(agent, data)
    end
    Analyzer-->>API: summary + risk report

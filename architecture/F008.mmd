sequenceDiagram
    participant Caller as Engine Caller
    participant Cache as RedisCache
    participant Redis as Redis

    Caller->>Cache: connect()
    Cache->>Redis: from_url(url, max_connections=20)
    Cache->>Redis: SCRIPT LOAD(TRUST_DECREMENT_LUA)
    Redis-->>Cache: script_sha
    Cache-->>Caller: connected

    Caller->>Cache: set_eval(ns:str, cls:str, tool:str, decision:PolicyDecision)
    Cache->>Cache: _jitter_ttl(base:int)->ttl:int
    Cache->>Redis: SETEX(eval:{ns}:{cls}:{tool}, ttl:int, decision_json:str)
    Redis-->>Cache: OK
    Cache-->>Caller: None

    Caller->>Cache: decrement_trust(spiffe_id:str)
    Cache->>Cache: _jitter_ttl(base:int)->ttl:int
    Cache->>Redis: EVALSHA(sha, key, penalty:float, threshold:float, ttl:int)
    Redis-->>Cache: trust_json:str|nil
    Cache-->>Caller: TrustScore|None


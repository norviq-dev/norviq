classDiagram
    class AttackGraphEngine {
      +compute_blast_radius(source_agent) BlastRadius
      +find_attack_paths(source, target, max_paths) list~AttackPath~
      +find_critical_paths() list~AttackPath~
      +find_chokepoints() list~dict~
      +compute_risk_matrix() dict
      +get_summary() dict
    }
    class AttackPath {
      +source: str
      +target: str
      +path: list~str~
      +path_risk: float
      +min_trust: float
    }
    class BlastRadius {
      +source: str
      +reachable_agents: list~str~
      +reachable_tools: list~str~
      +reachable_data: list~str~
      +risk_score: float
    }
    AttackGraphEngine --> AttackPath
    AttackGraphEngine --> BlastRadius

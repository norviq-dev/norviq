sequenceDiagram
    participant Caller
    participant Resolver as SPIFFEResolver
    participant Cache as _cache
    participant Env as os.environ

    Caller->>Resolver: resolve()
    Resolver->>Resolver: _get_cached()
    alt cache hit
        Resolver-->>Caller: AgentIdentity
    else cache miss
        Resolver->>Resolver: _resolve_from_socket()
        Resolver->>Env: read NRVQ_NAMESPACE/NRVQ_SERVICE_ACCOUNT/NRVQ_AGENT_CLASS
        Resolver->>Cache: store (identity, monotonic ts)
        Resolver-->>Caller: AgentIdentity
    end

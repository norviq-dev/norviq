classDiagram
    class AgentIdentity {
        +str spiffe_id
        +str namespace
        +str service_account = ""
        +str agent_class = ""
        +str framework = ""
        +str pod_name = ""
        +str cluster_id = ""
    }

    class ToolCallEvent {
        +str event_id
        +str tool_name
        +dict tool_params
        +AgentIdentity agent_identity
        +str session_id = ""
        +datetime timestamp_utc
        +str framework = ""
        +int call_depth = 0
        +str|None raw_llm_output = None
        +tool_name_not_empty(value: str) str
    }

    class PolicyDecision {
        +Literal decision
        +str policy_id = ""
        +int policy_version = 0
        +str rule_id = ""
        +str reason = ""
        +float trust_score = 0.0
        +float latency_ms = 0.0
        +str event_id = ""
        +datetime decided_at
        +is_blocked() bool
        +is_allowed() bool
        +is_escalated() bool
    }

    class AuditRecord {
        +str record_id
        +str event_id
        +str tool_name
        +str decision
        +str agent_id
        +str agent_class = ""
        +str namespace = ""
        +str policy_id = ""
        +int policy_version = 0
        +str rule_id = ""
        +str reason = ""
        +str session_id = ""
        +float trust_score = 0.0
        +float latency_ms = 0.0
        +datetime timestamp_utc
        +dict|None payload = None
        +from_event_and_decision(event, decision, payload) AuditRecord
    }


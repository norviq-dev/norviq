classDiagram
    class NrvqPolicyCRD {
      +map~string, any~ spec.target
      +string spec.enforcementMode
      +string spec.preset
      +string[] spec.rules
      +string spec.rego
      +int spec.priority
      +int spec.clusterPriority
      +string status.phase
    }
    class NrvqClassCRD {
      +string[] spec.allowedTools
      +string[] spec.blockedTools
      +int spec.maxCallsPerMinute
      +float spec.initialTrustScore
      +int status.agentCount
    }
    class NrvqConfigCRD {
      +GlobalConfig spec.global
      +TrustConfig spec.trust
      +RateLimitConfig spec.rateLimit
      +SidecarConfig spec.sidecar
      +TelemetryConfig spec.telemetry
    }
    class Controller {
      +dynamic.Interface client
      +string apiURL
      +string apiToken
      +http.Client httpClient
      +cache.Store policyStore
      +Start(context.Context) error
      +handlePolicy(any, string) void
      +handlePolicyDelete(any) void
      +syncPolicy(context.Context, policySyncRequest) error
      +syncDelete(context.Context, string) error
      +reconcileDeletingPolicy(context.Context, unstructured.Unstructured) void
    }
    class PolicyFunctions {
      +buildPolicySyncPayload(unstructured.Unstructured) policySyncRequest
      +validateRego(string) error
      +validateTarget(string, string, map~string, any~) error
      +validateClusterPriority(string, map~string, any~, string) error
      +isAllowedSidecarImage(string) bool
    }
    class Handler {
      +Config cfg
      +Injector injector
      +ValidatePolicy(http.ResponseWriter, http.Request) void
    }
    class NorviqAPI {
      +POST /api/v1/policies returns 2xx|error
      +DELETE /api/v1/policies/{namespace}/{name} returns 2xx|404|error
    }

    NrvqPolicyCRD --> Controller : watch/update
    Controller --> PolicyFunctions : payload/rego/image checks
    Controller --> NorviqAPI : sync policy state
    NrvqClassCRD --> NrvqPolicyCRD : referenced by target.agentClass
    NrvqConfigCRD --> Controller : cluster behavior inputs

classDiagram
    class FastAPIApp {
        +create_app() FastAPI
        +lifespan(app) AsyncContextManager
    }
    class RedisCache
    class OPAEvaluator
    class AuditEmitter
    class PolicyLoader
    class HealthRouter
    class PoliciesRouter
    class AuditRouter
    class AgentsRouter
    class AuditLogEntry
    class TrustScore
    class Auth {
        +get_current_user(creds) dict
        +decode_token(token) dict
        -_validate_token(token) dict
        -_validate_oidc(token, header) dict
        -_apply_group_mapping(claims) dict
        +require_admin(user)
        +scoped_namespace(user, requested) str
    }
    class JwksClient {
        +get_key(kid) dict
        -_refresh(force)
    }

    Auth --> JwksClient : OIDC RS256/ES256 (oidc_enabled)
    PoliciesRouter --> Auth : Depends(get_current_user)
    AuditRouter --> Auth : Depends(get_current_user)
    AgentsRouter --> Auth : Depends(get_current_user)
    FastAPIApp --> Auth : ws/audit decode_token
    FastAPIApp --> RedisCache : startup connect
    FastAPIApp --> OPAEvaluator : creates
    FastAPIApp --> AuditEmitter : creates
    FastAPIApp --> PolicyLoader : creates
    FastAPIApp --> HealthRouter : include_router
    FastAPIApp --> PoliciesRouter : include_router
    FastAPIApp --> AuditRouter : include_router
    FastAPIApp --> AgentsRouter : include_router
    PoliciesRouter --> PolicyLoader : CRUD
    AuditRouter --> AuditLogEntry : query
    AgentsRouter --> RedisCache : trust read/write
    AgentsRouter --> TrustScore : update model

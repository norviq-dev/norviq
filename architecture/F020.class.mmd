classDiagram
direction LR

class CLI {
  +cli(ctx, api_url, token, output)
  +status(ctx)
  +policy_list(ctx)
  +audit_stats(ctx, time_range, namespace)
  +agent_reset_trust(ctx, spiffe_id, score)
}

class APIClient {
  +get(path)
  +post(path, data)
  +put(path, data)
  +delete(path)
  -_request(method, path, data)
  -_http_error(exc)
}

class Formatters {
  +fmt_json(data)
  +fmt_table(data, columns)
  +fmt_policy(data)
}

CLI --> APIClient : uses
CLI --> Formatters : renders
APIClient --> HTTPX : wraps

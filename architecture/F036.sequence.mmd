sequenceDiagram
    participant Eval as Evaluator
    participant Graph as AssetGraphBuilder
    participant NX as networkx.DiGraph
    Eval->>Graph: record_tool_call(spiffe, tool, decision, ns, class)
    Graph->>NX: add_node(agent)
    Graph->>NX: add_node(tool)
    Graph->>NX: add_edge(agent->tool, calls)
    Graph->>Graph: record mapped tool->data edges
    Graph->>NX: add_node(data)
    Graph->>NX: add_edge(tool->data, accesses)
    Graph-->>Eval: graph updated

# Local Windows dev - Memurai + PostgreSQL 18
# Copy to .env.local and fill in values.

# PostgreSQL (local Windows install)
NRVQ_DB_HOST=127.0.0.1
NRVQ_DB_PORT=5433
NRVQ_DB_USER=norviq
NRVQ_DB_PASSWORD=<your_password_here>
NRVQ_DB_NAME=norviq
NRVQ_DB_URL=postgresql+asyncpg://norviq:<your_password_here>@127.0.0.1:5433/norviq?ssl=disable
# Compatibility with existing config field naming
NRVQ_PG_URL=postgresql://norviq:<your_password_here>@127.0.0.1:5433/norviq?sslmode=disable
NRVQ_DB_SSL_MODE=prefer

# Memurai (Redis-compatible on Windows)
NRVQ_REDIS_HOST=127.0.0.1
NRVQ_REDIS_PORT=6379
NRVQ_REDIS_PASSWORD=<optional_password_here>
NRVQ_REDIS_URL=redis://127.0.0.1:6379/0

# API
NRVQ_API_URL=http://127.0.0.1:8080
NRVQ_JWT_SECRET=<set_a_local_secret_here>
NRVQ_LOG_LEVEL=INFO

# Telemetry - disable for local (no OTel collector)
NRVQ_OTEL_ENDPOINT=
NRVQ_OTEL_DISABLED=true

# Local feature flags
NRVQ_DEBUG_OPA=true
NRVQ_ENFORCEMENT_MODE=block

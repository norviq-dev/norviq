#
# Reference list only. Nothing in this example auto-loads a .env file -- export these yourself,
# or point your own loader at a copy of this file.

# --- the LLM the demo agent uses -------------------------------------------------------------
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional. Any Groq model with reliable native tool-calling; this is the default in agent.py.
GROQ_MODEL=openai/gpt-oss-120b

# --- how the SDK reaches the policy engine (norviq/config.py) ---------------------------------
# PolicyEngineClient POSTs every tool call to <url>/api/v1/evaluate.
NRVQ_POLICY_ENGINE_URL=http://127.0.0.1:8080
# /api/v1/evaluate requires a bearer token. Get one with POST /api/v1/auth/login (see README).
NRVQ_API_TOKEN=

# --- the identity the decision is made against (norviq/engine/identity.py, mock mode) ---------
# These must match a namespace/agent class that actually has a policy loaded, or the call is
# denied: no_policy_decision defaults to "deny". scripts/seed-local-policies.py seeds exactly
# (default, customer-support).
NRVQ_NAMESPACE=default
NRVQ_AGENT_CLASS=customer-support

# Optional. One policy session id for the whole process (the LangChain adapter binds it at
# wrap time). Defaults to "demo-session".
NRVQ_SESSION_ID=demo-session
